kingVar":true,"isLocalVar":false,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"id следующей","m_stringValue":"","m_type":1,"supportsInput":false,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-7803505616086745305,"m_classType":"SetVariableAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"disableLogging":false,"m_SIGUID":-6149100530531384135,"m_classType":"EndIfAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"childrenCollapsed":false,"dontLogIfConditionIsFalse":false,"disableLogging":false,"m_SIGUID":-5299927279556383195,"m_classType":"IfConditionAction","m_constraintList":[{"comparisonType":0,"enableRegex":false,"ignoreCase":true,"type":0,"value1":"{lv\u003dдом}","value2":"true","disableLogging":false,"m_SIGUID":-6792983518063222406,"m_classType":"CompareValueConstraint","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_isDisabled":false,"m_isOrCondition":false},{"booleanDictionaryKeys":{"keys":[]},"dictionaryKeys":[],"dictionaryOrArrayType":-1,"existingManualKeyType":0,"m_booleanInvert":false,"m_darkMode":-1,"m_doubleRandomMax":0.0,"m_doubleRandomMin":0.0,"m_falseLabel":"Ложь","m_intExpression":false,"m_intRandom":false,"m_intRandomMax":0,"m_intRandomMin":0,"m_intValueDecrement":false,"m_intValueIncrement":false,"m_newBooleanValue":false,"m_newDoubleValue":0.0,"m_newIntValue":0,"m_trueLabel":"Истина","m_userPrompt":false,"m_userPromptEmptyAtStart":false,"m_userPromptPassword":false,"m_userPromptShowCancel":true,"m_userPromptStopAfterCancel":true,"m_variable":{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"дом","m_stringValue":"","m_type":0,"supportsInput":false,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-6571738433491924785,"m_classType":"SetVariableAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"blockNextAction":true,"consoleVariableName":"выход","javascriptEngine":"JetPack JavascriptEngine","scriptText":"/**\n * Находит ближайшую дату в будущем из массива дат.\n *\n * @param {string[]} dates - Массив строк с датами в формате \"YYYY-MM-DD HH:mm:ss\".\n * @returns {string|null} - Ближайшая дата в будущем или null, если все даты в прошлом или массив пуст.\n */\nfunction findNearestFutureDate(dates) {\n  if (!dates || dates.length \u003d\u003d\u003d 0) {\n    return null; // Обработка пустого массива\n  }\n\n  const now \u003d new Date();\n  let nearestFutureDate \u003d null;\n  let minDifference \u003d Infinity; // Инициализируем максимальной разницей\n\n  for (const dateString of dates) {\n    try {\n      const date \u003d new Date(dateString);\n\n      if (isNaN(date.getTime())) {\n        console.warn(`Некорректный формат даты: ${dateString}. Пропускаем.`);\n        continue; // Пропускаем некорректные даты\n      }\n\n      const difference \u003d date.getTime() - now.getTime(); // Разница в миллисекундах\n\n      if (difference \u003e 0 \u0026\u0026 difference \u003c minDifference) {\n        minDifference \u003d difference;\n        nearestFutureDate \u003d dateString;\n      }\n    } catch (error) {\n      console.error(`Ошибка при обработке даты ${dateString}:`, error); // Обработка ошибок при парсинге дат\n    }\n  }\n\n  return nearestFutureDate;\n}\n\n\n// Пример использования:\nconst dates \u003d [\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"{v\u003dОтвет словарь[stops][12][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][13][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][14][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][15][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][16][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][17][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][18][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][19][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][20][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][21][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][22][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][23][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][24][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][25][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][26][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][27][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][28][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][29][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][30][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][31][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][32][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][33][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][34][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][35][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][36][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][37][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][38][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][39][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][40][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][41][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][42][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][43][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][44][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][45][arrival]}\",\n]\nconst nearestDate \u003d findNearestFutureDate(dates);\nconst order_object \u003d dates.map(( item, index ) \u003d\u003e item.index)\nif (nearestDate) {\n  console.log(nearestDate, dates.indexOf(nearestDate)); // Выведет ближайшую дату к текущей в будущем\n} else {\n  console.log(\"Нет дат в будущем.\");\n}\n","stringVariableName":"","disableLogging":false,"m_SIGUID":-8074999083774932397,"m_classType":"JavaScriptAction","m_constraintList":[],"m