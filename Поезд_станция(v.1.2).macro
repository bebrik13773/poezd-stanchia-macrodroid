6396261383,"m_classType":"ElseAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"getByName":false,"m_GUID":-6772189927757365498,"m_enable":true,"m_macroName":"Уведомление поезд станция","m_state":-1,"m_userPromptTitle":"Состояние макроса","disableLogging":false,"m_SIGUID":-8939418565252486309,"m_classType":"DisableMacroAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"getByName":false,"isCategoryLocked":false,"m_GUID":-6772189927757365498,"m_ignoreConstraints":false,"m_macroName":"Уведомление поезд станция","m_useOffStatus":true,"m_userPromptTitle":"Выполнить макрос","m_waitToComplete":false,"disableLogging":false,"m_SIGUID":-8125244162529022377,"m_classType":"ForceMacroRunAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"disableLogging":false,"m_SIGUID":-9058051905605212223,"m_classType":"EndIfAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"color":-1,"label":"","disableLogging":false,"m_SIGUID":-9210692353819385347,"m_classType":"SeparatorAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"dontLogIfConditionIsFalse":false,"disableLogging":false,"m_SIGUID":-8714824416434618490,"m_classType":"ElseIfConditionAction","m_comment":"Получение информации","m_constraintList":[{"comparisonType":0,"enableRegex":false,"ignoreCase":true,"type":1,"value1":"{lv\u003dвыбор}","value2":"1","disableLogging":false,"m_SIGUID":-6040775328344297801,"m_classType":"CompareValueConstraint","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_isDisabled":false,"m_isOrCondition":false},{"m_vibratePattern":12,"disableLogging":false,"m_SIGUID":-7215203145352074619,"m_classType":"VibrateAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"blockNextAction":true,"consoleVariableName":"выход","javascriptEngine":"JetPack JavascriptEngine","scriptText":"/**\n * Находит ближайшую дату в будущем из массива дат.\n *\n * @param {string[]} dates - Массив строк с датами в формате \"YYYY-MM-DD HH:mm:ss\".\n * @returns {string|null} - Ближайшая дата в будущем или null, если все даты в прошлом или массив пуст.\n */\nfunction findNearestFutureDate(dates) {\n  if (!dates || dates.length \u003d\u003d\u003d 0) {\n    return null; // Обработка пустого массива\n  }\n\n  const now \u003d new Date();\n  let nearestFutureDate \u003d null;\n  let minDifference \u003d Infinity; // Инициализируем максимальной разницей\n\n  for (const dateString of dates) {\n    try {\n      const date \u003d new Date(dateString);\n\n      if (isNaN(date.getTime())) {\n        continue; // Пропускаем некорректные даты\n      }\n\n      const difference \u003d date.getTime() - now.getTime(); // Разница в миллисекундах\n\n      if (difference \u003e 0 \u0026\u0026 difference \u003c minDifference) {\n        minDifference \u003d difference;\n        nearestFutureDate \u003d dateString;\n      }\n    } catch (error) {\n      console.error(`Ошибка при обработке даты ${dateString}:`, error); // Обработка ошибок при парсинге дат\n    }\n  }\n\n  return nearestFutureDate;\n}\n\n\n// Пример использования:\nconst dates \u003d [\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"2028, 2, 20\",\n   \"{v\u003dОтвет словарь[stops][12][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][13][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][14][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][15][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][16][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][17][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][18][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][19][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][20][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][21][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][22][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][23][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][24][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][25][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][26][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][27][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][28][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][29][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][30][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][31][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][32][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][33][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][34][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][35][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][36][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][37][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][38][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][39][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][40][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][41][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][42][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][43][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][44][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][45][arrival]}\",\n]\nconst nearestDate \u003d findNearestFutureDate(dates);\nconst order_object \u003d dates.map(( item, index ) \u003d\u003e item.index)\nif (nearestDate) {\n  console.log(nearestDate, dates.indexOf(nearestDate)); // Выведет ближайшую дату к текущей в будущем\n} else {\n  console.log(\"Нет дат в будущем.\");\n}\n","stringVariableName":"","disableLogging":false,"m_SIGUID":-9162175783650309108,"m_classType":"JavaScriptAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_option":0,"m_text":"{v\u003dвыход}","m_textManipulation":{"type":"SubstringManipulation","params":["20","23"]},"variableName":"id следующей","disableLogging":false,"m_SIGUID":-7882538528945908159,"m_classType":"TextManipulationAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":f