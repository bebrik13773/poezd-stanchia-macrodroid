straintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"blockNextAction":true,"consoleVariableName":"выход","javascriptEngine":"JetPack JavascriptEngine","scriptText":"function преобразоватьДату(датаСтрока) {\n  const дата \u003d new Date(датаСтрока);\n\n  if (isNaN(дата.getTime())) {\n    return \"Неверный формат даты\"; // Обработка неверного формата\n  }\n\n  const год \u003d дата.getFullYear();\n  const месяц \u003d String(дата.getMonth() + 1).padStart(2, \u00270\u0027);\n  const день \u003d String(дата.getDate()).padStart(2, \u00270\u0027);\n  const часы \u003d String(дата.getHours()).padStart(2, \u00270\u0027);\n  const минуты \u003d String(дата.getMinutes()).padStart(2, \u00270\u0027);\n  const секунды \u003d String(дата.getSeconds()).padStart(2, \u00270\u0027);\n\n  return `${год}, ${месяц}, ${день}, ${часы}:${минуты}:${секунды}`;\n}\nconst data8 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][1][arrival]}\");\nconst data2 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][2][arrival]}\");\nconst data3 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][3][arrival]}\");\nconst data4 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][4][arrival]}\");\nconst data5 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][5][arrival]}\");\nconst data6 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][6][arrival]}\");\nconst data7 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][7][arrival]}\");\nconst data1 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][8][arrival]}\");\nconst data9 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][9][arrival]}\");\nconst data10 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][10][arrival]}\");\nconst data11 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][11][arrival]}\");\nconst data12 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][12][arrival]}\");\nconst data13 \u003d преобразоватьДату(\"{v\u003dОтвет словарь[stops][13][arrival]}\");\nconst data1