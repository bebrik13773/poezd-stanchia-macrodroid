_intValue":0,"m_name":"следующая остановка название","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-7463127958612249898,"m_classType":"SetVariableAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"blockNextAction":true,"consoleVariableName":"stoper times","javascriptEngine":"JetPack JavascriptEngine","scriptText":"const time \u003d \"{v\u003dОтвет словарь[stops][{v\u003did следующей}][stop_time]}\"\nconsole.log(time / 60)","stringVariableName":"","disableLogging":false,"m_SIGUID":-6558023614051665102,"m_classType":"JavaScriptAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"blockNextAction":true,"consoleVariableName":"Дата осталось до станции","javascriptEngine":"JetPack JavascriptEngine","scriptText":"function timeLeft(targetDateString) {\n  // 1. Преобразуем строку даты в объект Date.\n  const targetDate \u003d new Date(targetDateString);\n\n  // 2. Получаем текущую дату и время.\n  const now \u003d new Date();\n\n  // 3. Вычисляем разницу в миллисекундах между целевой датой и текущей датой.\n  const difference \u003d targetDate.getTime() - now.getTime();\n\n  // 4. Если разница отрицательная (целевая дата уже прошла), выводим сообщение.\n  if (difference \u003c 0) {\n    console.log(\"Эта дата уже прошла.\");\n    return; // Прекращаем выполнение функции, чтобы не выводить отрицательные значения.\n  }\n\n  // 5. Преобразуем разницу в дни, часы, минуты и секунды.\n  const days \u003d Math.floor(difference / (1000 * 60 * 60 * 24));\n  const hours \u003d Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));\n  const minutes \u003d Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));\n  const seconds \u003d Math.floor((difference % (1000 * 60)) / 1000);\n\n  // 6. Выводим результат в консоль.\n  console.log(`${days} дней, ${hours} часов, ${minutes} минут, ${seconds} секунд.`);\n}\n\n// Пример использования:\nconst targetDateString \u003d \"{v\u003dОтвет словарь[stops][{v\u003did следующей}][arrival]}\"; // Замените на вашу дату\ntimeLeft(targetDateString);","stringVariableName":"","disableLogging":false,"m_SIGUID":-7916732869504739005,"m_classType":"JavaScriptAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_option":0,"m_text":"{v\u003dОтвет словарь[stops][{v\u003did следующей}][arrival]}","m_textManipulation":{"type":"SubstringManipulation","params":["11","16"]},"variableName":"время след","disableLogging":false,"m_SIGUID":-7467746006208075590,"m_classType":"TextManipulationAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_option":0,"m_text":"{v\u003dДата осталось до станции}","m_textManipulation":{"type":"SubstringManipulation","params":["0","1"]},"variableName":"дни","disableLogging":false,"m_SIGUID":-6058249079358392642,"m_classType":"TextManipulationAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"booleanDictionaryKeys":{"keys":[]},"dictionaryKeys":[],"dictionaryOrArrayType":-1,"existingManualKeyType":0,"m_booleanInvert":false,"m_darkMode":-1,"m_doubleRandomMax":0.0,"m_doubleRandomMin":0.0,"m_falseLabel":"Ложь","m_intExpression":false,"m_intRandom":false,"m_intRandomMax":0,"m_intRandomMin":0,"m_intValueDecrement":false,"m_intValueIncrement":false,"m_newBooleanValue":true,"m_newDoubleValue":0.0,"m_newIntValue":0,"m_trueLabel":"Истина","m_userPrompt":false,"m_userPromptEmptyAtStart":false,"m_userPromptPassword":false,"m_userPromptShowCancel":true,"m_userPromptStopAfterCancel":true,"m_variable":{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"дом","m_stringValue":"","m_type":0,"supportsInput":false,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-5058411289146920741,"m_classType":"SetVariableAction","m_constrain