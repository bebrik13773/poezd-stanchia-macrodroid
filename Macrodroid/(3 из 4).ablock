11,"type":"DictionaryEntry"},{"key":"station_type_name","variable":{"textValue":"вокзал","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"transport_type","variable":{"textValue":"train","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"}],"isArray":false,"variableType":4,"type":"Dictionary"},"variableType":11,"type":"DictionaryEntry"},{"key":"departure","variable":{"textValue":"2026-02-04 07:37:00","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"arrival","variable":{"textValue":"2026-02-04 07:35:00","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"duration","variable":{"decimalValue":233640.0,"variableType":3,"type":"DecimalValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"stop_time","variable":{"decimalValue":120.0,"variableType":3,"type":"DecimalValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"platform","variable":{"textValue":"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"}],"isArray":false,"variableType":4,"type":"Dictionary"},"variableType":11,"type":"DictionaryEntry"},{"key":"46","variable":{"entries":[{"key":"station","variable":{"entries":[{"key":"type","variable":{"textValue":"station","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"title","variable":{"textValue":"Санкт-Петербург (Ладожский вокзал)","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"short_title","variable":{"textValue":"СПб-Лад.","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"popular_title","variable":{"textValue":"Ладожский вокзал","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"code","variable":{"textValue":"s9602499","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"station_type","variable":{"textValue":"train_station","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"station_type_name","variable":{"textValue":"вокзал","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"transport_type","variable":{"textValue":"train","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"}],"isArray":false,"variableType":4,"type":"Dictionary"},"variableType":11,"type":"DictionaryEntry"},{"key":"arrival","variable":{"textValue":"2026-02-04 09:40:00","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"duration","variable":{"decimalValue":241020.0,"variableType":3,"type":"DecimalValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"platform","variable":{"textValue":"","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"}],"isArray":false,"variableType":4,"type":"Dictionary"},"variableType":11,"type":"DictionaryEntry"}],"isArray":true,"variableType":5,"type":"Dictionary"},"variableType":11,"type":"DictionaryEntry"},{"key":"start_date","variable":{"textValue":"2026-02-01","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"},{"key":"start_time","variable":{"textValue":"18:43","variableType":2,"type":"StringValue"},"variableType":11,"type":"DictionaryEntry"}],"isArray":false,"parents":[],"variableType":4,"parentKeys":[],"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":false,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"Ответ словарь","m_stringValue":"","m_type":4,"supportsInput":false,"supportsOutput":true},{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":false,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"следующая остановка название","m_stringValue":"Шарья","m_type":2,"supportsInput":false,"supportsOutput":true},{"description":"","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":false,"isSecure":false,"m_booleanValue":false,"m_decimalValue":30.0,"m_intValue":30,"m_name":"id следующей","m_stringValue":"","m_type":1,"supportsInput":false,"supportsOutput":true},{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":false,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"stoper times","m_stringValue":"14","m_type":2,"supportsInput":false,"supportsOutput":true}],"macro":{"isInputExpanded":true,"isLocalExpanded":false,"isOutputExpanded":false,"isTestMode":false,"disabledTimestamp":0,"exportedActionBlocks":[],"forceEvenIfNotEnabledTimestamp":0,"isActionBlock":true,"isExtra":false,"isFavourite":false,"lastEditedTimestamp":1770357321819,"localVariables":[],"localVarsAlphabetical":true,"m_GUID":-8027182394620212293,"m_actionList":[{"m_fixedOptionCount":1,"m_option":2,"childrenCollapsed":false,"dontLogIfConditionIsFalse":true,"disableLogging":false,"m_SIGUID":-6580820059250549555,"m_classType":"LoopAction","m_constraintList":[{"identifier":"Данные","isShowing":true,"disableLogging":false,"m_SIGUID":-7936651774957364017,"m_classType":"CustomSceneConstraint","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_isDisabled":false,"m_isOrCondition":false},{"blockNextAction":true,"consoleVariableName":"выход","javascriptEngine":"JetPack JavascriptEngine","scriptText":"/**\n * Находит ближайшую дату в будущем из массива дат.\n *\n * @param {string[]} dates - Массив строк с датами в формате \"YYYY-MM-DD HH:mm:ss\".\n * @returns {string|null} - Ближайшая дата в будущем или null, если все даты в прошлом или массив пуст.\n */\nfunction findNearestFutureDate(dates) {\n  if (!dates || dates.length \u003d\u003d\u003d 0) {\n    return null; // Обработка пустого массива\n  }\n\n  const now \u003d new Date();\n  let nearestFutureDate \u003d null;\n  let minDifference \u003d Infinity; // Инициализируем максимальной разницей\n\n  for (const dateString of dates) {\n    try {\n      const date \u003d new Date(dateString);\n\n      if (isNaN(date.getTime())) {\n        continue; // Пропускаем некорректные даты\n      }\n\n      const difference \u003d date.getTime() - now.getTime(); // Разница в миллисекундах\n\n      if (difference \u003e 0 \u0026\u0026 difference \u003c minDifference) {\n        minDifference \u003d difference;\n        nearestFutureDate \u003d dateString;\n      }\n    } catch (error) {\n      console.error(`Ошибка при обработке даты ${dateString}:`, error); // Обработка ошибок при парсинге дат\n    }\n  }\n\n  return nearestFutureDate;\n}\n\n\n// Пример использования:\nconst dates \u003d [\n   \"2028, 2, 20\",\n   \"{v\u003dОтвет словарь[stops][1][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][2][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][3][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][4][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][5][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][6][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][7][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][8][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][9][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][10][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][11][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][12][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][13][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][14][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][15][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][16][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][17][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][18][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][19][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][20][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][21][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][22][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][23][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][24][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][25][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][26][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][27][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][28][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][29][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][30][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][31][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][32][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][33][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][34][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][35][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][36][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][37][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][38][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][39][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][40][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][41][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][42][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][43][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][44][arrival]}\",\n   \"{v\u003dОтвет словарь[stops][45][arrival]}\",\n]\nconst nearestDate \u003d findNearestFutureDate(dates);\nconst order_object \u003d dates.map(( item, index ) \u003d\u003e item.index)\nif (nearestDate) {\n  console.log(nearestDate, dates.indexOf(nearestDate)); // Выведет ближайшую дату к текущей в будущем\n} else {\n  console.log(\"Нет дат в будущем.\");\n}\n","disableLogging":false,"m_SIGUID":-7155863387942894199,"m_classType":"JavaScriptAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_option":0,"m_text":"{v\u003dвыход}","m_textManipulation":{"type":"SubstringManipulation","params":["20","23"]},"variableName":"id следующей","disableLogging":false,"m_SIGUID":-8722503046513193028,"m_classType":"TextManipulationAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"booleanDictionaryKeys":{"keys":[]},"dictionaryKeys":[],"dictionaryOrArrayType":-1,"existingManualKeyType":0,"m_booleanInvert":false,"m_darkMode":-1,"m_doubleRandomMax":0.0,"m_doubleRandomMin":0.0,"m_falseLabel":"Ложь","m_intExpression":false,"m_intRandom":false,"m_intRandomMax":0,"m_intRandomMin":0,"m_intValueDecrement":false,"m_intValueIncrement":false,"m_newBooleanValue":false,"m_newDoubleValue":0.0,"m_newIntValue":0,"m_newStringValue":"{v\u003dОтвет словарь[stops][{v\u003did следующей}][station][title]}","m_trueLabel":"Истина","m_userPrompt":false,"m_userPromptEmptyAtStart":false,"m_userPromptPassword":false,"m_userPromptShowCancel":true,"m_userPromptStopAfterCancel":true,"m_variable":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":false,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"следующая остановка название","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-9082058580162238211,"m_classType":"SetVariableAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"blockNextAction":true,"consoleVariableName":"stoper times","javascriptEngine":"JetPack JavascriptEngine","scriptText":"const time \u003d \"{v\u003dОтвет словарь[stops][{v\u003did следующей}][stop_time]}\"\nconsole.log(time / 60)","disableLogging":false,"m_SIGUID":-8557842491216286371,"m_classType":"JavaScriptAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"blockNextAction":true,"consoleVariableName":"Дата осталось до станции","javascriptEngine":"JetPack JavascriptEngine","scriptText":"function timeLeft(targetDateString) {\n  // 1. Преобразуем строку даты в объект Date.\n  const targetDate \u003d new Date(targetDateString);\n\n  // 2. Получаем текущую дату и время.\n  const now \u003d new Date();\n\n  // 3. Вычисляем разницу в миллисекундах между целевой датой и текущей датой.\n  const difference \u003d targetDate.getTime() - now.getTime();\n\n  // 4. Если разница отрицательная (целевая дата уже прошла), выводим сообщение.\n  if (difference \u003c 0) {\n    console.log(\"Эта дата уже прошла.\");\n    return; // Прекращаем выполнение функции, чтобы не выводить отрицательные значения.\n  }\n\n  // 5. Преобразуем разницу в дни, часы, минуты и секунды.\n  const days \u003d Math.floor(difference / (1000 * 60 * 60 * 24));\n  const hours \u003d Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));\n  const minutes \u003d Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));\n  const seconds \u003d Math.floor((difference % (1000 * 60)) / 1000);\n\n  // 6. Выводим результат в консоль.\n  console.log(`${days} дней, ${hours} часов, ${minutes} минут, ${seconds} секунд.`);\n}\n\n// Пример использования:\nconst targetDateString \u003d \"{v\u003dОтвет словарь[stops][{v\u003did следующей}][arrival]}\"; // Замените на вашу дату\ntimeLeft(targetDateString);","disableLogging":false,"m_SIGUID":-5077684237768773909,"m_classType":"JavaScriptAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_secondaryClassType":"OverlayDialogAction","autoExpand":true,"blockNextAction":false,"dimBackground":true,"disableHtml":false,"displayOverStatusBar":true,"iconText":"","iconType":0,"m_backgroundColor":-587202560,"m_iconBgColor":-769226,"m_imageResourceId":0,"m_macroGUIDToRun":0,"m_notificationChannelType":0,"m_notificationSubject":"Данные","m_notificationText":"Следующая станция:\n{v\u003dследующая остановка название}\nСтоим {v\u003dstoper times}мин.\nПриедем через {v\u003dДата осталось до станции}","m_overwriteExisting":false,"m_priority":0,"m_ringtoneIndex":0,"m_ringtoneName":"По умолчанию","m_runMacroWhenPressed":false,"m_textColor":-1,"maintainSpaces":false,"notificationActionButtons":[{"actionBlockData":{"actionBlockGuid":-8027182394620212293,"actionBlockName":"Данные поезд станция","inputVarsMap":{},"outputVarsMap":{}},"clearOnPress":